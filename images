            font-family: 'Inter', sans-serif;
            color: #e8e6e1;
            overflow-x: hidden;
            line-height: 1.4;
            cursor: default;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #1a1a1a;
        }
        ::-webkit-scrollbar-thumb {
            background: #c7a05b;
            border-radius: 8px;
        }

        section {
            position: relative;
